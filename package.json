{
  "name": "curios",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:api": "pnpm --filter @curios/api dev",
    "dev:web": "pnpm --filter @curios/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "lint-staged": {
    "packages/web/**/*.{ts,svelte,js,json,css,html}": "pnpm --filter @curios/web exec prettier --write",
    "packages/api/**/*.ts": "pnpm --filter @curios/web exec prettier --write",
    "packages/shared/**/*.ts": "pnpm --filter @curios/web exec prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
