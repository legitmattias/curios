PUBLIC_API_URL=http://localhost:4000

# Admin panel (/admin/*)
# ADMIN_PASSWORD: shared password required at /admin/login.
# ADMIN_SESSION_SECRET: HMAC secret for signing admin session cookies (long random string).
# DOSSIER_API_KEY: same value as in packages/api; used server-side by admin pages to proxy
# sync calls to the real API so the browser never sees it.
# ADMIN_API_URL (optional): override the API base used by admin proxies. Defaults to PUBLIC_API_URL.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
DOSSIER_API_KEY=
ADMIN_API_URL=
